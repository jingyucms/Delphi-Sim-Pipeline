
# KK2F build/work dir: it is reconstituted from the KK2F source at runtime, and its bulk is
# vendored sources + ~9.5MB of pretabulated tables + distribution default cards + artifacts.
# Ignore ALL of it EXCEPT the small DELPHI-custom steering cards (*.inp, *.tit). The custom
# driver DelKK_prod_25-Apr-2002.f is tracked at the generators/kk2f/ top level.
generators/kk2f/kk2f_build/*
!generators/kk2f/kk2f_build/*.inp
!generators/kk2f/kk2f_build/*.tit

# Output directories
output*/
condor_logs/
**/*_prod/
kk2f_isr_off_output/
kk2f_isr_on_output/
test_kk2f_output/

# Docker tar files
*.tar

# Container images (multi-GB, never tracked)
*.sif
*.sif.old-*
*.sif.bak

# Logs and scratch
*.log
docker_stderror

# Local test / run artifacts
test_fort.*
_validate_*
test_v2.16/
dag/
rescue/

# Compiled binaries (built next to each source by build_key4hep.sh)
/hepmc2fadgen
generators/pythia8_key4hep/closure_gen
generators/pythia8/pythia8_generate
generators/pythia8/photon_diag
generators/kk2f/kk2f_fadgen_fixer
__pycache__/
events.hepmc3
fort.26
fort26_conv

# Generator run artifacts (Sherpa/Herwig/Whizard scratch)
**/pythia8_run/
**/pythia8_key4hep_run/
**/sherpa_run/
**/herwig_run/
**/whizard_run/
**/kkmc_run/
kkmcee.hepmc
**/Process/
**/Results.zip
**/Results.zip~
**/Settings_Report/
References.tex
sherpa_events
herwig_events
whizard_events*
*.run
*.hepmc3
*.hepmc
*.log
