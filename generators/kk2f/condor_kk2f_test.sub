universe                = docker
docker_image            = registry.cern.ch/docker.io/jingyucms/delphi-kk2f:v2.8

# Arguments: [num_events] [job_id] [output_dir] [config_file]
arguments               = 3000 job_$(ClusterId)_$(Process) /afs/cern.ch/work/z/zhangj/delphi-pythia8-pipeline/kk2f_test_output kk2f_qq_ISR_on.tit

getenv                  = True
should_transfer_files   = YES
when_to_transfer_output = ON_EXIT

request_memory          = 4GB
request_cpus            = 1
request_disk            = 10GB

+JobFlavour             = "longlunch"

log                     = condor_logs/test_job_$(ClusterId)_$(Process).log
output                  = condor_logs/test_job_$(ClusterId)_$(Process).out
error                   = condor_logs/test_job_$(ClusterId)_$(Process).err

queue 5
